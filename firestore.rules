rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'oloyepromise@gmail.com'
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATION HELPERS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'points', 'updatedAt']) 
        && data.keys().size() >= 4
        && data.email is string && data.email.size() <= 256
        && data.role in ['user', 'admin']
        && data.points is number && data.points >= 0
        && data.updatedAt == request.time;
    }

    function isValidCampaign(data) {
      return data.keys().hasAll(['title', 'targetLink', 'active', 'createdAt', 'createdBy', 'currentEntries'])
        && data.title is string && data.title.size() <= 200
        && data.targetLink is string && data.targetLink.size() <= 500
        && data.active is bool
        && data.currentEntries is number
        && data.createdAt == request.time
        && data.createdBy == request.auth.uid;
    }

    function isValidCampaignUpdate(data) {
       return data.keys().hasAll(['title', 'targetLink', 'active', 'createdAt', 'createdBy', 'currentEntries'])
         && data.title is string && data.title.size() <= 200
         && data.targetLink is string && data.targetLink.size() <= 500
         && data.active is bool
         && data.currentEntries is number;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['userId', 'link', 'type', 'pointsEarned', 'createdAt', 'status'])
        && data.userId == request.auth.uid
        && data.link is string && data.link.size() <= 500
        && data.type in ['tweet', 'reply']
        && data.pointsEarned is number && data.pointsEarned > 0
        && data.createdAt == request.time
        && data.status == 'verified';
    }

    // -------------------------------------------------------------------------
    // RULES
    // -------------------------------------------------------------------------

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins collection - read only by signed in users, write only by existing admins
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // Leaderboard: any signed-in user can list users (ordered by points)
      // Admins can list all users for the user management panel
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId) 
        && isValidUser(request.resource.data)
        && (
          (request.resource.data.role == 'user' && request.resource.data.email != 'oloyepromise@gmail.com') ||
          (request.resource.data.role == 'admin' && request.resource.data.email == 'oloyepromise@gmail.com')
        )
        && request.resource.data.points == 0;
        
      allow update: if (isOwner(userId) || isAdmin())
        && isValidUser(request.resource.data)
        && (
          // Admin can change anything
          isAdmin() ||
          // User can only update their profile fields
          (
            request.resource.data.role == resource.data.role &&
            request.resource.data.points >= resource.data.points &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'updatedAt', 'displayName', 'photoURL'])
          )
        );
    }

    // Campaigns collection
    match /campaigns/{campaignId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() && isValidCampaign(request.resource.data);
      allow update: if (isAdmin() && isValidCampaignUpdate(request.resource.data)) ||
        (
          isSignedIn() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentEntries', 'active']) &&
          request.resource.data.currentEntries == resource.data.currentEntries + 1
        );
      allow delete: if isAdmin();
    }

    // Submissions collection
    match /submissions/{submissionId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn()
        && isValidSubmission(request.resource.data)
        && (
          (request.resource.data.type == 'tweet' && request.resource.data.pointsEarned == 2) ||
          (request.resource.data.type == 'reply') // Campaign points can vary, so we allow any for now or could check against campaign
        );
        
      allow update, delete: if false; // Submissions are immutable
    }
  }
}
